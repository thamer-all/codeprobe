{
  "name": "codeprobe",
  "version": "0.2.0",
  "description": "DevTools for AI Coding — context engineering toolkit for Claude, Cursor, Copilot, and more",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "codeprobe": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude",
    "anthropic",
    "context-engineering",
    "prompt-testing",
    "claude-code",
    "devtools",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "ajv": "^8.17.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0",
    "tiktoken": "^1.0.21",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
